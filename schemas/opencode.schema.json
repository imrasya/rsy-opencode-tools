{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Active OpenCode Configuration",
  "type": "object",
  "required": ["plugin"],
  "properties": {
    "$schema": { "type": "string" },
    "plugin": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": [
              { "type": "string", "minLength": 1 },
              { "type": "object" }
            ]
          }
        ]
      }
    },
    "mcp": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "enum": ["local", "remote"] },
          "command": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "url": { "type": "string", "minLength": 1 },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "enabled": { "type": "boolean" }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "local" } }, "required": ["type"] },
            "then": { "required": ["command"] }
          },
          {
            "if": { "properties": { "type": { "const": "remote" } }, "required": ["type"] },
            "then": { "required": ["url"] }
          }
        ],
        "additionalProperties": true
      }
    },
    "lsp": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["command", "extensions"],
        "properties": {
          "command": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "extensions": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
