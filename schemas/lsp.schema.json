{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LSP Servers Configuration",
  "type": "object",
  "required": ["lsp"],
  "properties": {
    "lsp": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["server", "command", "args", "filetypes", "installCommand"],
        "properties": {
          "server": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "filetypes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "installCommand": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
