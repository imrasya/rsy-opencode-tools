{
  "name": "rsy-opencode-tools",
  "version": "1.0.3",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./plugin": "./src/plugin/index.ts"
  },
  "bin": {
    "rsy-opencode-tools": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:sandbox": "bun run scripts/dev-sandbox.ts",
    "dev:sandbox:verify": "bun run scripts/dev-sandbox.ts --verify",
    "dev:opencode": "bun run scripts/dev-sandbox.ts && ./.dev-sandbox/run.sh",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "postinstall": "bun run scripts/postinstall.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/plugin": "^1.14.48",
    "@opencode-ai/sdk": "^1.14.48",
    "@opentui/solid": "^0.2.8",
    "ajv": "^8.20.0",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@babel/core": "^8.0.1",
    "fast-uri": "^3.1.2",
    "hono": "^4.12.25",
    "ip-address": "^10.1.1",
    "qs": "^6.15.2"
  },
  "_overridesRationale": {
    "fast-uri": "AJV URI resolver — pin past ReDoS/parse-handling advisories in older versions",
    "hono": "Transitive via @opencode-ai/* — pin past request-handling/path traversal advisories",
    "ip-address": "Transitive proxy/socks dep — pin past ReDoS-prone 6.x-8.x (CVE-2024-29415)",
    "qs": "Classic prototype-pollution/DoS history — pin past CVE-2022-24999 and related"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
